{
  "load": {
    "class_type": "VHS_LoadVideoPath",
    "_meta": { "title": "👉 VÍDEO a upscalar — cole o caminho ABSOLUTO do .mp4 aqui" },
    "inputs": {
      "video": "C:/Kaezan/StabilityMatrix/Data/Images/Text2Img/kaeli_bust_ui_00006.mp4",
      "force_rate": 0,
      "custom_width": 0,
      "custom_height": 0,
      "frame_load_cap": 0,
      "skip_first_frames": 0,
      "select_every_nth": 1
    }
  },
  "model": {
    "class_type": "UpscaleModelLoader",
    "_meta": { "title": "👉 Upscaler — 4xNomos2 (troque por um anime se 'fotografar' a pele/cabelo)" },
    "inputs": { "model_name": "4xNomos2_hq_dat2.safetensors" }
  },
  "up": {
    "class_type": "ImageUpscaleWithModel",
    "_meta": { "title": "Upscale 4x no batch (tiled fallback em 8 GB) — não mexer" },
    "inputs": { "upscale_model": ["model", 0], "image": ["load", 0] }
  },
  "scale": {
    "class_type": "ImageScaleBy",
    "_meta": { "title": "👉 escala final: 0.5 = net 2x (512→1024) · 1.0 = net 4x (2048)" },
    "inputs": { "image": ["up", 0], "upscale_method": "lanczos", "scale_by": 0.5 }
  },
  "save": {
    "class_type": "VHS_VideoCombine",
    "_meta": { "title": "Salva 1024² (pingpong=false: o loop já está nos frames de entrada)" },
    "inputs": {
      "images": ["scale", 0],
      "frame_rate": 16,
      "loop_count": 0,
      "filename_prefix": "kaeli_bust_up_ui",
      "format": "video/h264-mp4",
      "pingpong": false,
      "save_output": true
    }
  }
}
