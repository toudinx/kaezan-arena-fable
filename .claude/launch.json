{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "backend",
      "runtimeExecutable": "dotnet",
      "runtimeArgs": ["run", "--project", "backend/src/KaezanArenaFable.Api", "--urls", "http://localhost:5210"],
      "port": 5210,
      "autoPort": false
    },
    {
      "name": "frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "start", "--prefix", "frontend"],
      "port": 4200,
      "autoPort": false
    },
    {
      "name": "kaezan-fable-preview",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "start", "--prefix", "frontend", "--", "--port", "4321"],
      "port": 4321,
      "autoPort": true
    }
  ]
}
